[
  // ============================================================================
  // IOG COMPATIBILITY PATCHES
  //
  // When Interesting Ore Generation is installed, this file:
  //   1. Disables AG disc deposits not already disabled by IOG
  //   2. Creates iog-gen deposits in our empty placeholder files
  //
  // IOG's own interestingoregen: domain deposits are cleared in C# (AssetsLoaded)
  // to prevent block code validation errors from ore-rock combos AG doesn't register.
  //
  // Ore variant registrations are handled by base *-ore.json patches
  // WITHOUT IOG dependency, so they work with or without IOG installed.
  // ============================================================================

  // ============================================================================
  // 1. GALENA — hydrotubewithdepo (with nativesilver subdeposit)
  // ============================================================================

  // Create AG galena iog-gen deposit
  {
    "op": "add",
    "path": "/-",
    "value": {
      "code": "galena",
      "triesPerChunk": 0.001,
      "withOreMap": true,
      "handbookPageCode": "item-nugget-galena",
      "generator": "iog-gen",
      "attributes": {
        "inblock": {
          "veintype": "hydrotubewithdepo",
          "code": "rock-*",
          "name": "rock",
          "allowedVariants": ["shale", "limestone", "phyllite", "slate", "schist", "dolomite"]
        },
        "placeblock": {
          "code": "ore-*-galena-{rock}",
          "name": "grade",
          "allowedVariantsByInBlock": {
            "rock-shale": ["poor", "medium", "rich", "bountiful"],
            "rock-limestone": ["poor", "medium", "rich"],
            "rock-phyllite": ["poor", "medium", "rich", "bountiful"],
            "rock-slate": ["poor", "medium", "rich", "bountiful"],
            "rock-schist": ["poor", "medium", "rich"],
            "rock-dolomite": ["poor", "medium", "rich"]
          }
        },
        "subdeposit": {
          "code": "ore-*-galena_nativesilver-{rock}",
          "name": "grade",
          "allowedVariantsByInBlock": {
            "rock-shale": ["poor", "medium"],
            "rock-limestone": ["poor", "medium"],
            "rock-phyllite": ["poor", "medium"],
            "rock-slate": ["poor", "medium"],
            "rock-schist": ["poor", "medium"],
            "rock-dolomite": ["poor", "medium"]
          }
        },
        "radius": { "dist": "uniform", "avg": 5, "var": 2 },
        "yPosRel": { "dist": "uniform", "avg": 0.4, "var": 0.2 },
        "thickness": { "dist": "uniform", "avg": 2, "var": 1 },
        "branchCount": { "dist": "uniform", "avg": 8, "var": 4 },
        "branchLength": { "dist": "uniform", "avg": 48, "var": 24 },
        "OreSpongePercent": 0.3
      }
    },
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }],
    "side": "Server"
  },

