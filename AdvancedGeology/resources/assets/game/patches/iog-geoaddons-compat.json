[
  // ============================================================================
  // IOG + GEOADDONS COMPATIBILITY PATCHES
  //
  // Adds GeoAddons-only rocks (siltstone, mudstone, amphibolite) to IOG deposits
  // when BOTH Interesting Ore Generation and Geology Additions are installed.
  //
  // Secondary mineral childDeposits are injected via C# from
  // advancedgeology:config/iog-geoaddons-childdeposits.json. A Harmony patch
  // on IOG's TiltedDiscDepositGenerator populates subDepositsToPlace so that
  // vanilla's GenDeposits.GeneratePartial() processes the child deposits.
  // ============================================================================

  // ============================================================================
  // GALENA — add siltstone, mudstone to hydrotubewithdepo
  // iog-galena.json entry 0
  // ============================================================================

  // Add rocks to allowedVariants
  {
    "op": "add",
    "path": "/0/attributes/inblock/allowedVariants/-",
    "value": "siltstone",
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },
  {
    "op": "add",
    "path": "/0/attributes/inblock/allowedVariants/-",
    "value": "mudstone",
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },
  // Add grade mappings
  {
    "op": "add",
    "path": "/0/attributes/placeblock/allowedVariantsByInBlock/rock-siltstone",
    "value": ["poor", "medium", "rich"],
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },
  {
    "op": "add",
    "path": "/0/attributes/placeblock/allowedVariantsByInBlock/rock-mudstone",
    "value": ["poor", "medium"],
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },
  // Add subdeposit grade mappings
  {
    "op": "add",
    "path": "/0/attributes/subdeposit/allowedVariantsByInBlock/rock-siltstone",
    "value": ["poor", "medium"],
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },
  {
    "op": "add",
    "path": "/0/attributes/subdeposit/allowedVariantsByInBlock/rock-mudstone",
    "value": ["poor", "medium"],
    "file": "game:worldgen/deposits/metalore/iog-galena.json",
    "dependsOn": [{ "modid": "interestingoregen" }, { "modid": "geoaddons" }],
    "side": "Server"
  },

